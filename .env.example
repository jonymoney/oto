# oto — environment variables
# Copy to .env and fill in. In production these are set as Railway service
# variables (the ${{...}} examples are Railway reference-variable syntax).

# ── Server ────────────────────────────────────────────────────────────────
# Railway injects PORT at runtime; this is the local-dev default.
PORT=3001
# Canonical public URL of the MCP endpoint. Used as the `resource` value in
# OAuth Protected Resource Metadata and the WWW-Authenticate header.
# Production: https://<railway-domain>/mcp
MCP_SERVER_URL=http://localhost:3001/mcp
# 'oauth' (default) = full Supabase OAuth 2.1 handshake; 'disabled' = local dev
# bypass with a fixed dev user. NEVER set 'disabled' in production.
AUTH_MODE=oauth

# ── OpenAI (TTS generation) ───────────────────────────────────────────────
# https://platform.openai.com/api-keys — read automatically by the openai SDK.
OPENAI_API_KEY=sk-proj-...

# Generation defaults (gpt-4o-mini-tts: ~$0.015 per minute of audio)
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=coral
TTS_FORMAT=mp3

# ── Supabase (authentication ONLY) ────────────────────────────────────────
# Project URL — the backend derives the OAuth issuer (${SUPABASE_URL}/auth/v1)
# and JWKS URL (${SUPABASE_URL}/auth/v1/.well-known/jwks.json) from it.
SUPABASE_URL=https://rzkoyjmzmpigcvxfdhmc.supabase.co
# Publishable key (new sb_publishable_* format; replaces legacy anon key).
# Used by the consent-page frontend. Sent via `apikey` header.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret key (sb_secret_*; replaces service_role). OPTIONAL — only needed for
# Auth admin operations. Not required for JWT validation. Never expose.
# SUPABASE_SECRET_KEY=sb_secret_...

# ── Database (Railway Postgres) — audio history metadata ──────────────────
# Railway: DATABASE_URL=${{Postgres.DATABASE_URL}} (private network).
# Local dev: use the DATABASE_PUBLIC_URL from the Railway Postgres service.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Audio storage (Railway Storage Bucket, S3-compatible) ─────────────────
# Created via Railway canvas (+ New > Bucket). The bucket exposes these as
# reference variables: ${{<BucketName>.BUCKET}}, .ENDPOINT, .ACCESS_KEY_ID,
# .SECRET_ACCESS_KEY, .REGION. Audio is served via presigned GET URLs.
BUCKET_NAME=oto-audio-xxxxxxxxxxxx
BUCKET_ENDPOINT=https://storage.railway.app
BUCKET_REGION=auto
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
# Presigned GET URL lifetime (seconds)
AUDIO_URL_TTL_SECONDS=3600
